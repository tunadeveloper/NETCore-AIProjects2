@inject Microsoft.AspNetCore.Mvc.Rendering.IHtmlHelper Html
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" class="light-style layout-menu-fixed" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AI Projects Dashboard</title>
    <link rel="stylesheet" href="/sneat-1.0.0/assets/vendor/fonts/boxicons.css" />
    <link rel="stylesheet" href="/sneat-1.0.0/assets/vendor/css/core.css" />
    <link rel="stylesheet" href="/sneat-1.0.0/assets/vendor/css/theme-default.css" />
    <link rel="stylesheet" href="/sneat-1.0.0/assets/css/demo.css" />
</head>

<body>
    <div class="layout-wrapper layout-content-navbar">
        <div class="layout-container">
            <aside id="layout-menu" class="layout-menu menu-vertical menu bg-menu-theme">
                <div class="app-brand demo d-flex align-items-center justify-content-between px-3 py-2">
                    <a href="/" class="app-brand-link">
                        <span class="app-brand-text">🤖 AI PROJECTS</span>
                    </a>
                    <button id="toggle-theme">🌙</button>
                </div>

                <ul class="menu-inner py-1 mt-3">
                    <li class="menu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "DeepGramAIVoice" ? "active" : "")">
                        <a href="/DeepGramAIVoice/Index" class="menu-link">
                            <i class="menu-icon bx bx-microphone"></i>
                            <div>01 - Deepgram AI Voice</div>
                        </a>
                    </li>
                    <li class="menu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "HuggingFaceSentimentAnalysis" ? "active" : "")">
                        <a href="/HuggingFaceSentimentAnalysis/Index" class="menu-link">
                            <i class="menu-icon bx bx-happy"></i>
                            <div>02 - Sentiment Analysis</div>
                        </a>
                    </li>
                    <li class="menu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "HuggingFaceSummarizeText" ? "active" : "")">
                        <a href="/HuggingFaceSummarizeText/Index" class="menu-link">
                            <i class="menu-icon bx bx-book-open"></i>
                            <div>03 - Summarize Text</div>
                        </a>
                    </li>
                    <li class="menu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "HuggingFaceNamedEntityRecognition" ? "active" : "")">
                        <a href="/HuggingFaceNamedEntityRecognition/Index" class="menu-link">
                            <i class="menu-icon bx bx-highlight"></i>
                            <div>04 - Named Entity Recognition</div>
                        </a>
                    </li>
                    <li class="menu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "HuggingFaceRobertaBaseQA" ? "active" : "")">
                        <a href="/HuggingFaceRobertaBaseQA/Index" class="menu-link">
                            <i class="menu-icon bx bx-question-mark"></i>
                            <div>05 - Roberta Base QA</div>
                        </a>
                    </li>
                </ul>
            </aside>

            <div class="layout-page">
                <div class="content-wrapper">
                    <div class="container-xxl flex-grow-1 container-p-y">
                        @RenderBody()
                    </div>
                    <footer>
                        © <script>document.write(new Date().getFullYear());</script> Tunahan Cengiz
                    </footer>
                </div>
            </div>
        </div>
    </div>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            transition: background 0.3s, color 0.3s;
        }

        .app-brand-text {
            font-size: 22px;
            font-weight: 700;
            color: #444;
            transition: color 0.3s;
        }

        .menu-link {
            border-radius: 8px;
            transition: all 0.2s ease;
        }

            .menu-link:hover {
                background: #f3f4f6 !important;
                color: #111 !important;
                transform: translateX(4px);
            }

        .menu-item.active .menu-link {
            background: #e5e7eb !important;
            font-weight: 600;
        }

        body.dark {
            background: #1e1e2f;
            color: #e5e7eb;
        }

            body.dark .app-brand-text {
                color: #fff;
            }

            body.dark .menu-link:hover {
                background: #2a2a40 !important;
                color: #fff !important;
            }

            body.dark .menu-item.active .menu-link {
                background: #3a3a55 !important;
                color: #fff !important;
            }

            body.dark #layout-menu {
                background: #1b1b2f !important;
                border-right: 1px solid #2a2a40;
            }

            body.dark .layout-navbar,
            body.dark .content-wrapper {
                background: #1e1e2f !important;
            }

            body.dark .app-brand-link,
            body.dark .menu-link div,
            body.dark .menu-icon {
                color: #ddd !important;
            }

        footer {
            border-top: 1px solid #ddd;
            text-align: center;
            padding: 12px 0;
            font-size: 14px;
        }

        body.dark footer {
            border-top: 1px solid #333;
        }

        #toggle-theme {
            cursor: pointer;
            padding: 6px 12px;
            border-radius: 6px;
            border: none;
            background: #696cff;
            color: #fff;
            font-size: 14px;
            transition: background 0.3s;
        }

            #toggle-theme:hover {
                background: #4a4ef5;
            }

        body.dark #toggle-theme {
            background: #444;
        }

            body.dark #toggle-theme:hover {
                background: #666;
            }
    </style>
    <script>
        const toggleBtn = document.getElementById('toggle-theme');

        if (localStorage.getItem("theme") === "dark") {
            document.body.classList.add("dark");
            toggleBtn.textContent = "☀️";
        }

        toggleBtn.addEventListener('click', () => {
            document.body.classList.toggle('dark');

            if (document.body.classList.contains('dark')) {
                localStorage.setItem("theme", "dark");
                toggleBtn.textContent = "☀️";
            } else {
                localStorage.setItem("theme", "light");
                toggleBtn.textContent = "🌙";
            }
        });
    </script>
</body>
</html>
