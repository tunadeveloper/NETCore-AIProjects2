@{
    ViewData["Title"] = "Text Summarizer";
    Layout = "~/Views/Shared/_AILayout.cshtml";
}

<div class="col-12 col-lg-12 order-1 mb-4">
    <div class="card">
        <div class="card-header text-center">
            <h5 class="mb-0 fw-bold">🤖 HuggingFace Text Summarizer</h5>
        </div>
    </div>
</div>

<div class="col-12 col-lg-12 order-2 order-md-3 order-lg-2 mb-4">
    <div class="card">
        <div class="card-body text-center">
            <form asp-action="Index" asp-controller="HuggingFaceSummarizeText" method="post">
                <textarea name="text" class="form-control mb-3" rows="6"
                          placeholder="Özetlemek istediğiniz metni buraya yazın..."></textarea>
                <button type="submit" class="btn btn-primary">Özetle</button>
            </form>

            @if (ViewBag.Summarize != null)
            {
                <div class="mt-3">
                    <h6>Özet:</h6>
                    <p>@ViewBag.Summarize</p>
                </div>
            }
        </div>
    </div>
</div>
