@{
    ViewData["Title"] = "Audio To Text";
    Layout = "~/Views/Shared/_AILayout.cshtml";
}

<div class="col-12 col-lg-12 order-1 mb-4">
    <div class="card">
        <div class="card-header text-center">
            <h5 class="mb-0 fw-bold">Deep Gram AI Voice</h5>
        </div>
    </div>
</div>

<div class="col-12 col-lg-12 order-2 order-md-3 order-lg-2 mb-4">
    <div class="card">
        <div class="card-body text-center">
            <form asp-action="Index" asp-controller="DeepgramAIVoice" method="post" enctype="multipart/form-data">
                <input type="file" name="audioFile" accept=".mp3,.wav,.m4a" class="form-control mb-2" />
                <button type="submit" class="btn btn-primary">Yazıya Çevir</button>
            </form>

            @if (ViewBag.Transcript != null)
            {
                <div class="mt-3">
                    <h6>Transkript:</h6>
                    <p>@ViewBag.Transcript</p>
                </div>
            }
        </div>
    </div>
</div>
